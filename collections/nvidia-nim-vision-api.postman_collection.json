  "info": {
    "_postman_id": "3e8db7bd-fe6e-436e-b117-96a651075a88",
    "name": "NVIDIA NIM Vision Language Models API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Vision-language model inference through the standard /v1/chat/completions surface. Image inputs are passed as `image_url` content parts inside the messages array — either HTTPS URLs or base64 data URIs. Supports NVIDIA NeVA, microsoft/kosmos-2, phi-3-vision, llama-3.2-90b-vision-instruct, and other VLMs in the NIM catalog.\n\n\nContact Support:\n Name: NVIDIA Developer Support",
      "type": "text/plain"
    }
