  "info": {
    "_postman_id": "962494e1-eee4-4533-92af-03840c7d19db",
    "name": "NVIDIA NIM Speech API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "NVIDIA Riva-powered speech NIMs. Exposes automatic speech recognition (Parakeet, Canary), neural machine translation, and text-to-speech (Magpie-TTS, FastPitch) through HTTP surfaces. (Production deployments typically use the gRPC adapter for streaming; this OpenAPI documents the REST surface exposed by the hosted endpoint.)\n\n\nContact Support:\n Name: NVIDIA Developer Support",
      "type": "text/plain"
    }
  }
