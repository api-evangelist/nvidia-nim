  "info": {
    "_postman_id": "be5297e1-1560-4e7a-ac61-b94ff70577a5",
    "name": "NVIDIA NIM Embeddings API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "OpenAI-compatible embeddings endpoint backed by NVIDIA NeMo Retriever text embedding models. Returns dense float vectors for documents or queries. Supports `input_type=passage|query` for asymmetric retrieval and the standard `dimensions` parameter on models that allow dimension reduction.\n\n\nContact Support:\n Name: NVIDIA Developer Support",
      "type": "text/plain"
    }
  }
