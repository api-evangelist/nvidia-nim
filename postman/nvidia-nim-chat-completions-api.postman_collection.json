  "info": {
    "_postman_id": "db60dcff-a4ac-4d03-a95f-a04a8087254e",
    "name": "NVIDIA NIM Chat Completions API",
    "description": "OpenAI-compatible chat completions endpoint served by NVIDIA NIM. Available as a hosted service at https://integrate.api.nvidia.com/v1 and on every self-hosted NIM LLM container on port 8000. A single contract serves 100+ foundation models \u2014 Llama, Mistral, NVIDIA Nemotron, DeepSeek, Qwen, Phi, Gemma, Granite \u2014 through the standard /v1/chat/completions surface.\n\n\nContact Support:\n Name: NVIDIA Developer Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:13:21.000Z",
