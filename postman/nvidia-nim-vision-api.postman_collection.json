  "info": {
    "_postman_id": "66987998-e233-4453-9e82-3b2772d8b6dd",
    "name": "NVIDIA NIM Vision Language Models API",
    "description": "Vision-language model inference through the standard /v1/chat/completions surface. Image inputs are passed as `image_url` content parts inside the messages array \u2014 either HTTPS URLs or base64 data URIs. Supports NVIDIA NeVA, microsoft/kosmos-2, phi-3-vision, llama-3.2-90b-vision-instruct, and other VLMs in the NIM catalog.\n\n\nContact Support:\n Name: NVIDIA Developer Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:13:27.000Z",
