              "item": [
                {
                  "name": "Create A Multimodal Chat Completion",
                  "id": "05288c75-548c-498d-850d-164f098ae584",
                  "protocolProfileBehavior": {
                    "disableBodyPruning": true
                  },
                  "request": {
                    "method": "POST",
                    "header": [
                      {
                        "key": "Content-Type",
                        "value": "application/json"
                      },
                      {
                        "key": "Accept",
                        "value": "application/json"
                      }
                    ],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"model\": \"<string>\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"image_url\",\n          \"text\": \"<string>\",\n          \"image_url\": {\n            \"url\": \"<string>\"\n          }\n        },\n        {\n          \"type\": \"image_url\",\n          \"text\": \"<string>\",\n          \"image_url\": {\n            \"url\": \"<string>\"\n          }\n        }\n      ]\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": [\n        {\n          \"type\": \"image_url\",\n          \"text\": \"<string>\",\n          \"image_url\": {\n            \"url\": \"<string>\"\n          }\n        },\n        {\n          \"type\": \"text\",\n          \"text\": \"<string>\",\n          \"image_url\": {\n            \"url\": \"<string>\"\n          }\n        }\n      ]\n    }\n  ],\n  \"max_tokens\": \"<integer>\",\n  \"temperature\": \"<number>\",\n  \"stream\": \"<boolean>\"\n}",
                      "options": {
                        "raw": {
                          "headerFamily": "json",
                          "language": "json"
                        }
                      }
                    },
                    "url": {
                      "raw": "{{baseUrl}}/v1/chat/completions",
                      "host": [
                        "{{baseUrl}}"
                      ],
                      "path": [
                        "v1",
                        "chat",
                        "completions"
                      ]
                    },
                    "description": "Generate a chat completion against a vision-language model. Image content is supplied via `image_url` parts inside the user message; the response mirrors the standard chat completions schema.\n"
